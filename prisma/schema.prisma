generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("TECHNICIAN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  technicianProfile TechnicianProfile?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TechnicianProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  fullName      String
  cpf           String   @unique
  phone         String
  email         String
  city          String
  pixKey        String
  pixKeyType    String
  iaAssistLogin String?
  cnpj               String?
  razaoSocial        String?
  nomeFantasia       String?
  tabelaValoresPath  String?
  tabelaValoresName  String?
  tabelaValoresSize  Int?
  contractType       String?  @default("AUTONOMO")
  status             String   @default("CADASTRO_INICIADO")
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ── Homologação / fluxo Contrato-Mãe ─────────────────────────────────────
  // Dados CNPJ (JSON da BrasilAPI)
  cnpjData               String?
  cnpjCheckedAt          DateTime?
  cnpjSituacao           String?   // ATIVA | INAPTA | BAIXADA | SUSPENSA | NULA | IRREGULAR

  // Contrato-Mãe
  masterContractVersion       String?   // contrato_mae_v1 | v2 | ...
  masterContractSignedAt      DateTime?
  masterContractSignedName    String?
  masterContractSignedDocument String?
  masterContractData          String?   // JSON snapshot completo com auditoria

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  closings Closing[]
  disputes ClosingDispute[]
  advances PaymentAdvance[]
  reimbursements      Reimbursement[]
  providerTechnicians ProviderTechnician[]
  cnpjAuditLogs       CnpjAuditLog[]
}

// ── Técnico Responsável da empresa prestadora ─────────────────────────────────
model ProviderTechnician {
  id           String   @id @default(cuid())
  technicianId String

  nomeCompleto  String
  cpf           String
  telefone      String
  email         String
  funcao        String
  especialidade String
  cidade        String
  uf            String
  // SOCIO | REPRESENTANTE | EMPREGADO | PARCEIRO | PREPOSTO | TECNICO_INDICADO
  vinculo       String

  isPrincipal  Boolean  @default(false)
  isRepLegal   Boolean  @default(false)  // rep legal também é o técnico
  declaracaoAceita Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
}

// ── Log de consultas de CNPJ ──────────────────────────────────────────────────
model CnpjAuditLog {
  id           String   @id @default(cuid())
  technicianId String
  cnpj         String
  situacao     String?
  ativo        Boolean  @default(false)
  rawResponse  String?   // JSON completo da BrasilAPI
  ip           String?
  consultedAt  DateTime @default(now())

  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId])
  @@index([consultedAt])
}

model Closing {
  id             String   @id @default(cuid())
  technicianId   String
  competence     String
  periodStart    DateTime
  periodEnd      DateTime
  totalValue     Float
  serviceCount   Int      @default(0)
  status         String   @default("AWAITING_CLOSING")
  observations   String?
  adminNotes     String?
  reportFilePath       String?
  reportFileName       String?
  reportFileSize       Int?
  scheduledPaymentDate DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  viewedAt             DateTime?

  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  services   ClosingService[]
  invoice    Invoice?
  dispute    ClosingDispute?
  advance    PaymentAdvance?
  events     ClosingEvent[]
  emailLogs  EmailLog[]
}

model ClosingEvent {
  id          String   @id @default(cuid())
  closingId   String
  eventType   String
  statusFrom  String?
  statusTo    String?
  description String?
  adminNote   String?
  createdBy   String   @default("system")
  createdAt   DateTime @default(now())

  closing  Closing   @relation(fields: [closingId], references: [id], onDelete: Cascade)
  emailLog EmailLog?
}

model EmailLog {
  id         String    @id @default(cuid())
  closingId  String
  eventId    String?   @unique
  recipient  String
  subject    String
  template   String
  status     String    @default("PENDING")
  error      String?
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  closing Closing       @relation(fields: [closingId], references: [id], onDelete: Cascade)
  event   ClosingEvent? @relation(fields: [eventId], references: [id])
}

model ClosingDispute {
  id           String   @id @default(cuid())
  closingId    String   @unique
  technicianId String
  reason       String
  claimedValue Float
  status       String   @default("PENDING")
  adminNotes   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  closing    Closing           @relation(fields: [closingId], references: [id], onDelete: Cascade)
  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model PaymentAdvance {
  id            String   @id @default(cuid())
  closingId     String   @unique
  technicianId  String
  originalValue Float
  feePercent    Float    @default(10)
  feeValue      Float
  netValue      Float
  status        String   @default("PENDING")
  signedAt      DateTime
  signedName    String
  signedCnpj    String?
  adminNotes    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  closing    Closing           @relation(fields: [closingId], references: [id], onDelete: Cascade)
  technician TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model ClosingService {
  id          String   @id @default(cuid())
  closingId   String
  description String
  value       Float
  serviceDate DateTime
  createdAt   DateTime @default(now())

  closing Closing @relation(fields: [closingId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(cuid())
  closingId     String   @unique
  invoiceNumber String
  competence    String
  value         Float
  observations  String?
  filePath      String
  fileName      String
  fileSize      Int
  mimeType      String
  sentAt        DateTime @default(now())
  contractSignedAt       DateTime?
  contractSignedName     String?
  contractSignedDocument String?
  contractData           String?
  createdAt     DateTime @default(now())

  closing Closing @relation(fields: [closingId], references: [id], onDelete: Cascade)
}

model Reimbursement {
  id           String   @id @default(cuid())
  technicianId String
  description  String
  totalValue   Float
  pixKey       String
  pixKeyType   String   @default("CPF")
  status       String   @default("PENDING")
  adminNotes   String?
  contractSignedAt       DateTime?
  contractSignedName     String?
  contractSignedDocument String?
  contractData           String?
  scheduledPaymentDate DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  technician  TechnicianProfile        @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  items       ReimbursementItem[]
  attachments ReimbursementAttachment[]
}

model ReimbursementItem {
  id              String        @id @default(cuid())
  reimbursementId String
  description     String
  category        String
  value           Float
  createdAt       DateTime      @default(now())

  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)
}

model ReimbursementAttachment {
  id              String        @id @default(cuid())
  reimbursementId String
  filePath        String
  fileName        String
  fileSize        Int
  mimeType        String
  createdAt       DateTime      @default(now())

  reimbursement   Reimbursement @relation(fields: [reimbursementId], references: [id], onDelete: Cascade)
}

model TechnicianApplication {
  id                     String   @id @default(cuid())
  fullName               String
  cpfCnpj                String
  whatsapp               String
  email                  String
  cidade                 String
  bairro                 String?
  especialidadePrincipal String
  outrasEspecialidades   String?
  atende24h              Boolean  @default(false)
  possuiVeiculo          Boolean  @default(false)
  emiteNotaFiscal        Boolean  @default(false)
  trabalhoTipo           String?
  disponibilidade        String?
  tempoExperiencia       String?
  observacoes            String?
  status                 String   @default("PENDING")
  adminNotes             String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ── Templates de Contratos (editáveis pelo admin) ────────────────────────────
model ContractTemplate {
  id        String   @id @default(cuid())
  type      String   // CONTRATO_MAE | TERMO_FECHAMENTO | TERMO_REEMBOLSO
  version   String   @default("v1")
  title     String
  content   String   // Texto completo com tags {{VARIAVEL}}
  variables String?  // JSON — lista de variáveis disponíveis
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
}

// ── Auditoria de Login ────────────────────────────────────────────────────────
model LoginAudit {
  id        String   @id @default(cuid())
  userId    String?
  techName  String?
  email     String?
  event     String   // login_success | login_failure | logout | blocked
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([event])
}

// ── Eventos do Site (visitas, cliques, formulários) ───────────────────────────
model SiteEvent {
  id        String   @id @default(cuid())
  event     String   // page_view | whatsapp_click | form_submit | login_start | etc.
  page      String?
  referrer  String?
  userAgent String?
  ip        String?
  city      String?  // Cidade via header x-vercel-ip-city (geolocalização Vercel)
  isDesktop Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([event])
  @@index([page])
}
